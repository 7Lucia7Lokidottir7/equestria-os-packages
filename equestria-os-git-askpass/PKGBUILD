# Maintainer: Equestria OS Team

pkgname=equestria-os-git-askpass
pkgver=1.0.0
pkgrel=7
pkgdesc="Native GUI Git credential interceptor for Equestria OS (fixes Unity Git errors)"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('git' 'python-pyqt6')
install="$pkgname.install"

package() {
    local _lib="$pkgdir/usr/lib/$pkgname"
    install -dm755 "$_lib"

    for f in equestria-os-git-askpass.py style.qss localization.csv EquestriaOS-Logo.png; do
        install -Dm644 "$startdir/$f" "$_lib/$f"
    done

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-os-git-askpass" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-os-git-askpass/
exec python3 equestria-os-git-askpass.py "$@"
EOF

    install -Dm644 "$startdir/EquestriaOS-Logo.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-git-askpass.png"

    # profile.d — sets SSH_ASKPASS for login shells
    install -Dm644 /dev/stdin "$pkgdir/etc/profile.d/equestria-os-git-askpass.sh" << 'EOF'
export SSH_ASKPASS=/usr/bin/equestria-os-git-askpass
EOF
}
