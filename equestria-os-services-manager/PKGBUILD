# Maintainer: Equestria OS Team

pkgname=equestria-os-services-manager
pkgver=2.1.0
pkgrel=2
pkgdesc="Official Equestria OS Service Manager (Enable, Disable, Start, Stop)"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('polkit')

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-services-manager" \
        "$pkgdir/usr/bin/equestria-os-services-manager"

    sed "s|^Exec=.*|Exec=equestria-os-services-manager|" \
        "$startdir/equestria-os-services-manager.desktop" \
        > "$pkgdir/usr/share/applications/equestria-os-services-manager.desktop"
    chmod 644 "$pkgdir/usr/share/applications/equestria-os-services-manager.desktop"

    install -Dm644 "$startdir/equestria-os-services-manager.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-services-manager.png"
}
