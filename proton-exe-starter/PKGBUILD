# Maintainer: Equestria OS Team

pkgname=equestria-os-proton-starter
pkgver=1.5.3
pkgrel=2
pkgdesc="Native Windows .exe launcher for Equestria OS (double-click support via Proton)"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')

depends=(
    'python-pyqt6'
    'umu-launcher'
    'lib32-glibc'
    'lib32-gcc-libs'
    'xdg-utils'
    'desktop-file-utils'
    'xdg-desktop-portal-kde'
    'libxcb'
    'libx11'
)
optdepends=(
    'lib32-mesa: 32-bit OpenGL support for AMD/Intel/Nouveau'
    'lib32-vulkan-radeon: 32-bit Vulkan support for AMD GPUs'
    'lib32-vulkan-intel: 32-bit Vulkan support for Intel GPUs'
    'lib32-nvidia-utils: 32-bit OpenGL/Vulkan support for NVIDIA GPUs'
)
install="$pkgname.install"

package() {
    local _lib="$pkgdir/usr/lib/equestria-proton-starter"
    install -dm755 "$_lib"

    for f in dispatch.py main.py launcher.py cleaner.py proton_runner.py ui.py style.qss localization.csv EquestriaOS-Logo.png; do
        install -Dm644 "$startdir/$f" "$_lib/$f"
    done

    # Three entry points, each calling the appropriate module directly
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-proton-settings" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-proton-starter/
exec python3 main.py "$@"
EOF

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-proton-run" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-proton-starter/
exec python3 launcher.py "$@"
EOF

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-proton-cleaner" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-proton-starter/
exec python3 cleaner.py "$@"
EOF

    install -Dm644 "$startdir/EquestriaOS-Logo.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-proton-starter.png"

    install -Dm644 "$startdir/equestria-os-proton-run.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-proton-run.desktop"
    install -Dm644 "$startdir/equestria-os-proton-cleaner.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-proton-cleaner.desktop"
    install -Dm755 "$startdir/equestria-os-proton.desktop" \
        "$pkgdir/usr/share/kio/servicemenus/equestria-os-proton.desktop"
    install -Dm644 "$startdir/mimeapps.list" \
        "$pkgdir/usr/share/applications/mimeapps.list"
}
