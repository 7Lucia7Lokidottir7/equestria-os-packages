# Maintainer: Equestria OS Team <info@psyche-games.com>

pkgname=pg-rankmirrors
pkgver=2.0.0
pkgrel=1
pkgdesc='Equestria OS — Mirror manager with country selection'
arch=('any')
license=('GPL3')
url='https://psyche-games.com'
depends=('python' 'python-pyqt6' 'reflector' 'polkit')

package() {
    local appdir="$pkgdir/opt/$pkgname"

    install -d "$appdir"
    install -d "$pkgdir/usr/bin"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    cp "$startdir/main.py" "$appdir/"
    cp "$startdir/ui_mirrors.py" "$appdir/"
    cp "$startdir/style.qss" "$appdir/"
    cp "$startdir/equestria_cyrillic.ttf" "$appdir/"

    chmod 755 "$appdir/main.py"

    install -Dm755 "$startdir/pg-rankmirrors-backend" "$pkgdir/usr/bin/pg-rankmirrors-backend"

    cat > "$pkgdir/usr/bin/pg-rankmirrors" << 'WRAPPER'
#!/bin/bash
exec python3 /opt/pg-rankmirrors/main.py "$@"
WRAPPER
    chmod 755 "$pkgdir/usr/bin/pg-rankmirrors"

    install -Dm644 "$startdir/pg-rankmirrors.desktop" "$pkgdir/usr/share/applications/pg-rankmirrors.desktop"

    # Уникальное имя иконки: pg-rankmirrors.png
    if [ -f "$startdir/EquestriaOS-Logo.png" ]; then
        install -Dm644 "$startdir/EquestriaOS-Logo.png" "$pkgdir/usr/share/pixmaps/pg-rankmirrors.png"
    fi
}
