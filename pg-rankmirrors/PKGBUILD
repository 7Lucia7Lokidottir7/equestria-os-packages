# Maintainer: Equestria OS Team <info@psyche-games.com>

pkgname=pg-rankmirrors
pkgver=2.1.0
pkgrel=3
pkgdesc='Equestria OS — Mirror manager with country selection'
arch=('x86_64')
license=('GPL3')
url='https://psyche-games.com'
depends=('reflector' 'polkit')
install='pg-rankmirrors.install'

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/pg-rankmirrors" \
        "$pkgdir/usr/bin/pg-rankmirrors"

    install -Dm755 "$startdir/pg-rankmirrors-backend" \
        "$pkgdir/usr/bin/pg-rankmirrors-backend"

    install -d "$pkgdir/usr/share/applications"
    sed "s|^Exec=.*|Exec=pg-rankmirrors|" \
        "$startdir/pg-rankmirrors.desktop" \
        > "$pkgdir/usr/share/applications/pg-rankmirrors.desktop"
    chmod 644 "$pkgdir/usr/share/applications/pg-rankmirrors.desktop"

    install -Dm644 "$startdir/pg-rankmirrors.service" "$pkgdir/usr/lib/systemd/system/pg-rankmirrors.service"
    install -Dm644 "$startdir/pg-rankmirrors.timer"   "$pkgdir/usr/lib/systemd/system/pg-rankmirrors.timer"
    install -Dm644 "$startdir/pg-rankmirrors.hook"    "$pkgdir/usr/share/libalpm/hooks/pg-rankmirrors.hook"

    if [ -f "$startdir/EquestriaOS-Logo.png" ]; then
        install -Dm644 "$startdir/EquestriaOS-Logo.png" "$pkgdir/usr/share/pixmaps/pg-rankmirrors.png"
    fi
}
