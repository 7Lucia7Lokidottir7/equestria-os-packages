# Maintainer: Equestria OS Team

pkgname=equestria-os-builder
pkgver=1.0.0
pkgrel=4
pkgdesc="GUI frontend for PyInstaller — build any Python app into a standalone executable"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('python-pyqt6')
optdepends=('python-pyinstaller: required to actually build apps')

package() {
    local _lib="$pkgdir/usr/lib/$pkgname"
    install -dm755 "$_lib"

    install -Dm644 "$startdir/main.py" "$_lib/main.py"

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-os-builder" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-os-builder/
exec python3 main.py "$@"
EOF

    install -Dm644 "$startdir/equestria-os-builder.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-builder.desktop"
}
