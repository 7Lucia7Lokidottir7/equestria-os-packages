# Maintainer: Equestria OS Team

pkgname=equestria-os-builder
pkgver=1.0.0
pkgrel=3
pkgdesc="GUI frontend for PyInstaller — build any Python app into a standalone executable"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=()

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-builder" \
        "$pkgdir/usr/bin/equestria-os-builder"

    install -Dm644 "$startdir/equestria-os-builder.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-builder.desktop"
}
