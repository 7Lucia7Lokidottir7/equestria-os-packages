post_install() {
    echo "[equestria-nvidia-dkms] Initializing NVIDIA kernel modules..."
    /usr/lib/equestria-nvidia-dkms/equestria-nvidia-dkms-update --no-initramfs || true
}

post_upgrade() {
    post_install
}

pre_remove() {
    local ver
    ver=$(dkms status nvidia 2>/dev/null | grep -oP 'nvidia/\K[^,]+' | head -1)
    [ -n "$ver" ] && dkms remove -m nvidia -v "$ver" --all 2>/dev/null || true
    [ -n "$ver" ] && rm -rf "/usr/src/nvidia-${ver}" || true
}
