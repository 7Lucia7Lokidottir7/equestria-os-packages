# Maintainer: Equestria OS Team
#
# Proprietary NVIDIA kernel modules — самообновляемый пакет.
#
# Версия пакета не привязана к версии драйвера.
# При обновлении nvidia-utils через pacman -Syu:
#   → pacman-хук автоматически скачивает новый .run от NVIDIA
#   → пересобирает DKMS модули ядра
#   → никаких ручных действий не требуется
#
# Поддерживаемые GPU:
#   Pascal (GTX 10xx)   — GP102/GP104/GP106/GP108
#   Maxwell (GTX 9xx/750) — GM107/GM108/GM200/GM204/GM206
#   Volta (Titan V)     — GV100
#
# nvidia-open-dkms (Turing+) не поддерживает эти архитектуры.
# Arch удалил проприетарный nvidia-dkms из репозиториев в v580.

pkgname=equestria-nvidia-dkms
pkgver=1.0
pkgrel=1
pkgdesc='Self-updating proprietary NVIDIA modules (DKMS) for Pascal/Maxwell/Volta — Equestria OS'
arch=('x86_64')
url='https://github.com/equestria-os'
license=('LicenseRef-NVIDIA-proprietary')
depends=('dkms' 'nvidia-utils' 'libglvnd' 'curl' 'bash')
optdepends=('linux-headers: build modules for linux kernel'
            'linux-lts-headers: build modules for linux-lts kernel')
conflicts=('nvidia-open-dkms' 'nvidia-open' 'nvidia-open-lts'
           'nvidia-dkms' 'nvidia' 'nvidia-lts')
provides=('NVIDIA-MODULE' 'nvidia-dkms')
install=equestria-nvidia-dkms.install

source=(
    'equestria-nvidia-dkms-update'
    'equestria-nvidia-dkms.hook'
)
sha256sums=('SKIP' 'SKIP')

package() {
    # Скрипт обновления DKMS исходника
    install -Dm755 equestria-nvidia-dkms-update \
        "$pkgdir/usr/lib/equestria-nvidia-dkms/equestria-nvidia-dkms-update"

    # Pacman-хук: запускает обновление при смене nvidia-utils
    install -Dm644 equestria-nvidia-dkms.hook \
        "$pkgdir/usr/share/libalpm/hooks/equestria-nvidia-dkms.hook"
}
