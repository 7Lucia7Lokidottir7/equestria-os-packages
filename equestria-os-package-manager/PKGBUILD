# Maintainer: Equestria OS Team

pkgname=equestria-os-package-manager
pkgver=2.2.1
pkgrel=3
pkgdesc="Official Equestria OS Package Manager (Uninstall and Manage)"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('polkit')

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-package-manager" \
        "$pkgdir/usr/bin/equestria-os-package-manager"

    sed "s|^Exec=.*|Exec=equestria-os-package-manager|" \
        "$startdir/equestria-os-package-manager.desktop" \
        > "$pkgdir/usr/share/applications/equestria-os-package-manager.desktop"
    chmod 644 "$pkgdir/usr/share/applications/equestria-os-package-manager.desktop"

    install -Dm644 "$startdir/equestria-os-package-manager.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-package-manager.png"
}
