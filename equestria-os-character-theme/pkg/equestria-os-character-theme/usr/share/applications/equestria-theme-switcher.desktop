#!/usr/bin/env xdg-open
[Desktop Entry]
Name=Equestria Theme Switcher
Comment=Switch EG character themes in EquestriaOS
Exec=python /opt/equestria-os-character-theme/main.py
Icon=equestria-os-logo
Terminal=false
Type=Application
Categories=Settings;DesktopSettings;Qt;
StartupNotify=true
StartupWMClass=equestria-theme-switcher
