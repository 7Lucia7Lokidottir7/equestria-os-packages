# Maintainer: Equestria OS Team

pkgname=equestria-os-character-theme
pkgver=2.0.3
pkgrel=3
pkgdesc="Customizing the visual style and characters of Equestria OS"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=()

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-character-theme" \
        "$pkgdir/usr/bin/equestria-os-character-theme"

    sed "s|^Exec=.*|Exec=equestria-os-character-theme|" \
        "$startdir/equestria-theme-switcher.desktop" \
        > "$pkgdir/usr/share/applications/equestria-theme-switcher.desktop"
    chmod 644 "$pkgdir/usr/share/applications/equestria-theme-switcher.desktop"

    install -Dm644 "$startdir/EquestriaOS-Logo.png" \
        "$pkgdir/usr/share/pixmaps/equestria-theme-switcher.png"
}
