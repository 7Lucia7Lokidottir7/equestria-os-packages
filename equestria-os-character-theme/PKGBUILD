# Maintainer: Equestria OS Team

pkgname=equestria-os-character-theme
pkgver=2.0.3
pkgrel=5
pkgdesc="Customizing the visual style and characters of Equestria OS"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('python-pyqt6')

package() {
    local _lib="$pkgdir/usr/lib/$pkgname"
    install -dm755 "$_lib"

    for f in main.py ui.py style.qss equestria_cyrillic.ttf characters.json localization.csv; do
        install -Dm644 "$startdir/$f" "$_lib/$f"
    done

    cp -a "$startdir/MLP Cutiemarks" "$_lib/"
    cp -a "$startdir/Wallpapers" "$_lib/"

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-os-character-theme" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-os-character-theme/
exec python3 main.py "$@"
EOF

    install -d "$pkgdir/usr/share/applications"
    sed "s|^Exec=.*|Exec=equestria-os-character-theme|" \
        "$startdir/equestria-theme-switcher.desktop" \
        > "$pkgdir/usr/share/applications/equestria-theme-switcher.desktop"
    chmod 644 "$pkgdir/usr/share/applications/equestria-theme-switcher.desktop"

    if [ -f "$startdir/EquestriaOS-Logo.png" ]; then
        install -Dm644 "$startdir/EquestriaOS-Logo.png" \
            "$pkgdir/usr/share/pixmaps/equestria-theme-switcher.png"
    fi
}
