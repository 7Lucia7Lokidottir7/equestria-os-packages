# Maintainer: Equestria OS Team

pkgname=equestria-os-character-theme
pkgver=2.0.0
pkgrel=1
pkgdesc='Customizing the visual style and characters of Equestria OS'
arch=('any')
url='https://psyche-games.com'
license=('custom')
depends=('python' 'python-pyqt6')

package() {
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    cp "$startdir/main.py" "$pkgdir/opt/$pkgname/"
    cp "$startdir/ui.py" "$pkgdir/opt/$pkgname/"
    cp "$startdir/style.qss" "$pkgdir/opt/$pkgname/"
    cp "$startdir/equestria_cyrillic.ttf" "$pkgdir/opt/$pkgname/"
    cp "$startdir/localization.csv" "$pkgdir/opt/$pkgname/"

    if [ -f "$startdir/start.sh" ]; then
        cp "$startdir/start.sh" "$pkgdir/opt/$pkgname/"
        chmod 755 "$pkgdir/opt/$pkgname/start.sh"
    fi

    chmod 755 "$pkgdir/opt/$pkgname/main.py"

    if [ -f "$startdir/equestria-theme-switcher.desktop" ]; then
        install -Dm644 "$startdir/equestria-theme-switcher.desktop" "$pkgdir/usr/share/applications/equestria-theme-switcher.desktop"
    fi

    # Опционально: если закинешь сюда картинку, она тоже поставится без конфликтов
    if [ -f "$startdir/EquestriaOS-Logo.png" ]; then
        install -Dm644 "$startdir/EquestriaOS-Logo.png" "$pkgdir/usr/share/pixmaps/equestria-theme-switcher.png"
    fi
}
