# Maintainer: Equestria OS Team <info@psyche-games.com>

pkgname=equestria-os-branding
pkgver=1.3.0
pkgrel=4
pkgdesc="Official Equestria OS Visual Style (SDDM, GRUB, Plasma Splash, and Cutiemarks)"
arch=('any')
url="https://github.com/Lucia7Lunadottir"
license=('custom')

provides=('equestria-os-branding')

source=()

package() {
    # 1. SDDM тема
    if [ -d "$startdir/sddm/equestria-os-breeze" ]; then
        install -d "$pkgdir/usr/share/sddm/themes"
        cp -r "$startdir/sddm/equestria-os-breeze" "$pkgdir/usr/share/sddm/themes/"
    fi

    # 2. GRUB тема
    if [ -d "$startdir/grub/equestria-os" ]; then
        install -d "$pkgdir/usr/share/grub/themes"
        cp -r "$startdir/grub/equestria-os" "$pkgdir/usr/share/grub/themes/"
    fi

    # 3. Plasma Splash Screen (Look and Feel)
    if [ -d "$startdir/look-and-feel/Equestria-OS" ]; then
        install -d "$pkgdir/usr/share/plasma/look-and-feel"
        cp -r "$startdir/look-and-feel/Equestria-OS" "$pkgdir/usr/share/plasma/look-and-feel/"
    fi

    # 4. Plasma Lockscreen — файлы хранятся в нашей директории, применяются
    #    через pacman-хук (см. hooks/equestria-os-lockscreen.hook).
    #    KDE Plasma 6 не поддерживает lockscreen через look-and-feel,
    #    поэтому используем хук, который автоматически копирует файлы
    #    после установки/обновления plasma-desktop или этого пакета.
    if [ -d "$startdir/plasma-lockscreen" ]; then
        install -d "$pkgdir/usr/share/equestria-os/plasma-lockscreen"
        cp -r "$startdir/plasma-lockscreen/"* "$pkgdir/usr/share/equestria-os/plasma-lockscreen/"
    fi

    # 4a. Скрипт применения lockscreen
    install -Dm755 "$startdir/scripts/apply-lockscreen.sh" \
        "$pkgdir/usr/lib/equestria-os/apply-lockscreen.sh"

    # 4b. Pacman хук — запускается после install/upgrade plasma-desktop или этого пакета
    install -Dm644 "$startdir/hooks/equestria-os-lockscreen.hook" \
        "$pkgdir/usr/share/libalpm/hooks/equestria-os-lockscreen.hook"

    # 5. Cutiemarks
    install -d "$pkgdir/usr/share/equestria-os/cutiemarks"
    if [ -d "$startdir/cutiemarks" ]; then
        cp -r "$startdir/cutiemarks/"* "$pkgdir/usr/share/equestria-os/cutiemarks/" 2>/dev/null || true
    fi

    # 6. Cursor theme
    if [ -d "$startdir/icons/Vimix-white-cursors" ]; then
        install -d "$pkgdir/usr/share/icons"
        cp -r "$startdir/icons/Vimix-white-cursors" "$pkgdir/usr/share/icons/"
    fi

    # 7. Только уникальные наши pixmaps
    install -d "$pkgdir/usr/share/pixmaps"
    for f in \
        equestria-os.png \
        equestria-os-character-theme.png \
        equestria-os-package-installer.png \
        pgos_logo_final.png; do
        if [ -f "$startdir/pixmaps/$f" ]; then
            install -Dm644 "$startdir/pixmaps/$f" "$pkgdir/usr/share/pixmaps/$f"
        fi
    done

    # 8. App submenu — groups all Equestria OS tools under one entry in the app menu
    install -Dm644 "$startdir/equestria-os.directory" \
        "$pkgdir/usr/share/desktop-directories/equestria-os.directory"
    install -Dm644 "$startdir/equestria-os.menu" \
        "$pkgdir/etc/xdg/menus/applications-merged/equestria-os.menu"
    install -Dm644 "$startdir/equestria-os.menu" \
        "$pkgdir/etc/xdg/menus/plasma-applications-merged/equestria-os.menu"
}
