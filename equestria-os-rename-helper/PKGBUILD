# Maintainer: Equestria OS Team

pkgname=equestria-os-rename-helper
pkgver=1.0.0
pkgrel=1
pkgdesc="Bulk file renaming utility with Find and Replace"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=()

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-rename-helper" \
        "$pkgdir/usr/bin/equestria-os-rename-helper"
}
