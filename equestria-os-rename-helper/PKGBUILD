# Maintainer: Equestria OS Team

pkgname=equestria-os-rename-helper
pkgver=1.0.0
pkgrel=3
pkgdesc="Bulk file renaming utility with Find and Replace"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('python-pyqt6')

package() {
    local _lib="$pkgdir/usr/lib/$pkgname"
    install -dm755 "$_lib"

    for f in rename_app.py core.py privilege.py style.qss equestria_cyrillic.ttf; do
        install -Dm644 "$startdir/$f" "$_lib/$f"
    done

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-os-rename-helper" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-os-rename-helper/
exec python3 rename_app.py "$@"
EOF
}
