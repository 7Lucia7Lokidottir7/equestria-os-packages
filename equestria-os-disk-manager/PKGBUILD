# Maintainer: Equestria OS Team

pkgname=equestria-os-disk-manager
pkgver=1.1.0
pkgrel=3
pkgdesc="GUI tool for managing disks: mount, fstab, permissions, labels, format"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('polkit')
optdepends=(
    'kdesu: alternative privilege elevation'
    'ntfs-3g: NTFS read/write support and ntfslabel'
    'btrfs-progs: btrfs label and filesystem tools'
    'exfatprogs: exFAT format and label support'
    'dosfstools: FAT32 format and label support (mkfs.vfat, fatlabel)'
)

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-disk-manager" "$pkgdir/usr/bin/equestria-disk-manager"
    install -Dm755 "$_bins/equestria-os-disk-backend"  "$pkgdir/usr/bin/equestria-os-disk-backend"

    install -Dm644 "$startdir/equestria-os-disk-manager.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-disk-manager.desktop"

    install -Dm644 "$startdir/equestria-os-disk-manager.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-disk-manager.png"
}
