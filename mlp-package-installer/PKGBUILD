# Maintainer: Equestria OS Team

pkgname=mlp-package-installer
pkgver=1.0.0
pkgrel=1
pkgdesc='The official Equestria OS app and driver store'
arch=('x86_64')
url='https://psyche-games.com'
license=('custom')
options=('!strip') # КРИТИЧЕСКИ ВАЖНО: не ломать бинарники Unity

package() {
    # 1. Создаем системные папки
    install -d "$pkgdir/opt/$pkgname"
    install -d "$pkgdir/usr/share/applications"
    install -d "$pkgdir/usr/share/pixmaps"

    # 2. Копируем файлы игры (исполняемый, библиотеки и папку Data)
    cp -r "$startdir/MLP Package Installer.x86_64" "$pkgdir/opt/$pkgname/"
    cp -r "$startdir/MLP Package Installer_Data" "$pkgdir/opt/$pkgname/"
    cp -r "$startdir/"*.so "$pkgdir/opt/$pkgname/"

    # 3. Выдаем файлам права на исполнение
    chmod 755 "$pkgdir/opt/$pkgname/MLP Package Installer.x86_64"
    chmod 755 "$pkgdir/opt/$pkgname/"*.so

    # 4. Копируем ярлык для меню приложений
    install -Dm644 "$startdir/mlp-package-installer.desktop" "$pkgdir/usr/share/applications/"

    # 5. Копируем твой логотип как иконку системы
    install -Dm644 "$startdir/EquestriaOS-Logo.png" "$pkgdir/usr/share/pixmaps/mlp-package-installer.png"
}
