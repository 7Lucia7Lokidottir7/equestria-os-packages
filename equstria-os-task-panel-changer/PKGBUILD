# Maintainer: Equestria OS Team

pkgname=equestria-os-task-panel-changer
pkgver=1.2.2
pkgrel=4
pkgdesc="Task panel style manager for Equestria OS (KDE Plasma 6)"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('python-pyqt6')
install="$pkgname.install"

package() {
    local _lib="$pkgdir/usr/lib/$pkgname"
    install -dm755 "$_lib"

    for f in main.py plasma_utils.py ui.py widgets.py style.qss equestria_cyrillic.ttf localization.csv presets.json restore_panel.sh save_panel.sh EquestriaOS-Logo.png; do
        install -Dm644 "$startdir/$f" "$_lib/$f"
    done
    chmod 755 "$_lib/restore_panel.sh" "$_lib/save_panel.sh"

    cp -a "$startdir/MLP Cutiemarks" "$_lib/"

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-os-task-panel-changer" << 'EOF'
#!/bin/bash
cd /usr/lib/equestria-os-task-panel-changer/
exec python3 main.py "$@"
EOF

    install -Dm644 "$startdir/equestria-os-task-panel-changer.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-task-panel-changer.desktop"
}
