# Maintainer: Equestria OS Team

pkgname=equestria-os-swap-manager
pkgver=2.0.1
pkgrel=3
pkgdesc="GUI tool for managing swap files, partitions, and swappiness"
arch=('any')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('polkit' 'python-pyqt6')
optdepends=('kdesu: alternative privilege elevation')

package() {
    local _lib="$pkgdir/opt/equestria-os/$pkgname"
    install -dm755 "$_lib"

    for f in swap_app.py swap_backend.py core.py privilege.py style.qss equestria_cyrillic.ttf check_mark.svg equestria-os-swap-manager.png; do
        install -Dm644 "$startdir/$f" "$_lib/$f"
    done

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-swap-manager" << 'EOF'
#!/bin/bash
cd /opt/equestria-os/equestria-os-swap-manager/
exec python3 swap_app.py "$@"
EOF

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/equestria-os-swap-backend" << 'EOF'
#!/bin/bash
cd /opt/equestria-os/equestria-os-swap-manager/
exec python3 swap_backend.py "$@"
EOF

    install -Dm644 "$startdir/equestria-os-swap-manager.desktop" \
        "$pkgdir/usr/share/applications/equestria-os-swap-manager.desktop"

    install -Dm644 "$startdir/equestria-os-swap-manager.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-swap-manager.png"
}
