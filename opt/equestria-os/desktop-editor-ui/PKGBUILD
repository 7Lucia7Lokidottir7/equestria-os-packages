# Maintainer: Tвой Ник

pkgname=desktop-editor-ui
pkgver=1.0.0
pkgrel=6
pkgdesc="Утилита для быстрого создания и редактирования .desktop файлов"
arch=('any')
depends=('python-pyqt6')

# Явно указываем makepkg, какие файлы нужно взять из папки проекта
source=('desktop_editor_ui.py'
        'style.qss'
        'desktop-editor-ui.png'
        'locales.json')

# Пропускаем проверку хэшей для локальных файлов разработчика
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    local _lib="$pkgdir/opt/equestria-os/$pkgname"
    install -dm755 "$_lib"

    # Теперь $srcdir содержит наши файлы! Копируем скрипт, стили, иконку и переводы
    install -Dm644 "$srcdir/desktop_editor_ui.py" "$_lib/desktop_editor_ui.py"
    install -Dm644 "$srcdir/style.qss" "$_lib/style.qss"
    install -Dm644 "$srcdir/desktop-editor-ui.png" "$_lib/desktop-editor-ui.png"
    install -Dm644 "$srcdir/locales.json" "$_lib/locales.json"

    # Системная иконка для меню Пуск
    install -Dm644 "$srcdir/desktop-editor-ui.png" "$pkgdir/usr/share/pixmaps/desktop-editor-ui.png"

    # Создаем бинарник для запуска
    install -dm755 "$pkgdir/usr/bin"
    cat << 'EOF' > "$pkgdir/usr/bin/desktop-editor"
#!/bin/bash
cd /opt/equestria-os/desktop-editor-ui/
exec python3 desktop_editor_ui.py "$@"
EOF
    chmod 755 "$pkgdir/usr/bin/desktop-editor"

    # Создаем мультиязычный .desktop файл
    install -dm755 "$pkgdir/usr/share/applications"
    cat << 'EOF' > "$pkgdir/usr/share/applications/desktop-editor-ui.desktop"
[Desktop Entry]
Type=Application
Name=Desktop File Editor
Name[ru]=Редактор .desktop файлов
Name[de]=Desktop-Datei-Editor
Name[es]=Editor de archivos .desktop
Name[fr]=Éditeur de fichiers .desktop
Name[ja]=.desktop ファイルエディタ
Name[pl]=Edytor plików .desktop
Name[pt]=Editor de arquivos .desktop
Name[uk]=Редактор .desktop файлів
Name[zh]=Desktop 文件编辑器
Comment=Create and edit .desktop shortcut files
Comment[ru]=Создание и редактирование файлов ярлыков .desktop
Comment[de]=Erstellen und Bearbeiten von .desktop-Verknüpfungsdateien
Comment[es]=Crea y edita archivos de acceso directo .desktop
Comment[fr]=Créer et modifier des fichiers de raccourcis .desktop
Comment[ja]=.desktop ショートカットファイルの作成と編集
Comment[pl]=Tworzenie i edycja plików skrótów .desktop
Comment[pt]=Criar e editar arquivos de atalho .desktop
Comment[uk]=Створення та редагування файлів ярликів .desktop
Comment[zh]=创建和编辑 .desktop 快捷方式文件
Exec=desktop-editor
Icon=desktop-editor-ui
Categories=Utility;System;Settings;
Terminal=false
StartupWMClass=desktop-editor-ui
EOF
    chmod 644 "$pkgdir/usr/share/applications/desktop-editor-ui.desktop"
}
