# Maintainer: Equestria OS Team

pkgname=equestria-os-software-center
pkgver=1.3.1
pkgrel=2
pkgdesc="Центр программного обеспечения для Equestria OS"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=('pacman' 'yay')

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-software-center" \
        "$pkgdir/usr/bin/equestria-os-software-center"

    sed "s|^Exec=.*|Exec=equestria-os-software-center|" \
        "$startdir/equestria-os-software-center.desktop" \
        > "$pkgdir/usr/share/applications/equestria-os-software-center.desktop"
    chmod 644 "$pkgdir/usr/share/applications/equestria-os-software-center.desktop"

    install -Dm644 "$startdir/equestria-os-software-center.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-software-center.png"
}
