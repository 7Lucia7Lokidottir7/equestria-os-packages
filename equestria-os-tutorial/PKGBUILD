# Maintainer: Equestria OS Team

pkgname=equestria-os-tutorial
pkgver=1.4.0
pkgrel=5
pkgdesc="Interactive tour for new Equestria OS users"
arch=('x86_64')
url="https://github.com/Lucia7Lunadottir"
license=('GPL')
depends=()

package() {
    local _bins="$(dirname "$startdir")/../equestria-packages-builds/bins"

    install -Dm755 "$_bins/equestria-os-tutorial" "$pkgdir/usr/bin/equestria-os-tutorial"

    install -d "$pkgdir/usr/share/applications"
    sed "s|^Exec=.*|Exec=equestria-os-tutorial|" "$startdir/equestria-os-tutorial.desktop" \
        > "$pkgdir/usr/share/applications/equestria-os-tutorial.desktop"
    chmod 644 "$pkgdir/usr/share/applications/equestria-os-tutorial.desktop"

    install -Dm644 "$startdir/tutorial.png" \
        "$pkgdir/usr/share/pixmaps/equestria-os-tutorial.png"
}
